# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Admin API keys for management endpoints (e.g., creating user secrets)
# These are used to access /admin/* endpoints
# Comma-separated if multiple admin keys are needed
VPS_API_KEYS=change-me-admin-api-key

# Pairing completion is intentionally unauthenticated for UX.
# App must provide:
# - pairing_code (from start)
# - pairing_pin (second factor shown by agent at start)
# No auth header is required on /pair/complete.

# Note: User secrets are no longer configured here.
# Secrets are now auto-generated by the server when an agent registers.
#
# Agent registration flow:
# 1. Start the server
# 2. Agent calls POST /register with {"agent_id": "my-agent", ...}
# 3. Server auto-generates a secret, stores it in the database, and returns it
# 4. Agent uses the returned secret as X-Secret header for:
#    - Client requests (GET/POST /relay/{agent_id}/...)
#    - Heartbeat (if applicable)
#
# The secret-as-identity model means:
# - Each agent registration gets a unique secret on first registration
# - Re-registrations reuse the existing secret
# - The same secret is used for both server (agent) registration and client access
# - Users are isolated - a client can only access their own agent